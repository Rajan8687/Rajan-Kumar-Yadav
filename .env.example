# ===========================================
# FLASK PORTFOLIO/BLOG - ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# -------------------------------------------
# REQUIRED SETTINGS
# -------------------------------------------

# Secret key for session security (generate a random one)
# Use: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-this

# Admin credentials (for first login)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# -------------------------------------------
# DATABASE SETTINGS
# -------------------------------------------

# Default: SQLite (file-based, no config needed)
# DATABASE_URL=sqlite:///blog.db

# For PostgreSQL (production recommended):
# DATABASE_URL=postgresql://username:password@localhost:5432/dbname

# For MySQL:
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/dbname

# -------------------------------------------
# MAIL SETTINGS (For Contact Form)
# -------------------------------------------

# SMTP Server Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false

# Your email credentials
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password  # For Gmail: use App Password (not regular password)
MAIL_FROM=your-email@gmail.com

# For Outlook/Hotmail:
# MAIL_SERVER=smtp.office365.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=your-email@outlook.com
# MAIL_PASSWORD=your-password

# For Yahoo:
# MAIL_SERVER=smtp.mail.yahoo.com
# MAIL_PORT=465
# MAIL_USE_SSL=true

# -------------------------------------------
# OPTIONAL SETTINGS
# -------------------------------------------

# Flask debug mode (development only)
FLASK_DEBUG=false

# Flask environment
FLASK_ENV=development

# Port to run on (default: 5000)
PORT=5000

# Host to bind to
HOST=0.0.0.0
